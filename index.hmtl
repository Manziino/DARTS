<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Darts Score Counter</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#121214">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
        body { background-color: #121214; color: #e2e8f0; padding: 15px; -webkit-user-select: none; user-select: none; }
        .container { max-width: 500px; margin: 0 auto; }
        h1, h2, h3 { text-align: center; color: #00adb5; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; }
        .card { background: #1e1e24; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); margin-bottom: 20px; border: 1px solid #2d2d35; }
        .hidden { display: none !important; }
        
        /* Setup Screen */
        .mode-selector, .setup-buttons { display: flex; gap: 10px; margin-bottom: 15px; }
        .btn { flex: 1; padding: 12px; border: none; border-radius: 8px; font-weight: bold; font-size: 16px; cursor: pointer; transition: all 0.2s; background: #2d2d35; color: #e2e8f0; }
        .btn-active { background: #00adb5; color: #121214; }
        .btn-primary { background: #ff5722; color: white; width: 100%; margin-top: 10px; padding: 15px; font-size: 18px; }
        .input-group { display: flex; gap: 10px; margin-bottom: 15px; }
        input { flex: 1; padding: 12px; border-radius: 8px; border: 1px solid #2d2d35; background: #121214; color: white; font-size: 16px; }
        .player-badge { display: flex; justify-content: space-between; align-items: center; background: #121214; padding: 10px 15px; border-radius: 6px; margin-bottom: 8px; border-left: 4px solid #00adb5; }
        .remove-btn { color: #ff5722; font-weight: bold; cursor: pointer; background: none; border: none; font-size: 16px; }

        /* Game Screen */
        .scoreboard { display: grid; grid-template-columns: 1fr; gap: 10px; margin-bottom: 15px; }
        .player-row { display: flex; justify-content: space-between; align-items: center; padding: 15px; background: #2d2d35; border-radius: 8px; border: 2px solid transparent; }
        .player-row.active { border-color: #00adb5; background: #1e1e24; box-shadow: 0 0 10px rgba(0, 173, 181, 0.2); }
        .player-info { display: flex; flex-direction: column; }
        .player-name { font-size: 18px; font-weight: bold; }
        .player-last-turn { font-size: 12px; color: #a0aec0; margin-top: 4px; }
        .player-score { font-size: 32px; font-weight: 900; color: #fff; }
        .player-row.active .player-score { color: #00adb5; }

        /* Keypad */
        .keypad-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 10px; }
        .key { background: #2d2d35; font-size: 24px; font-weight: bold; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: none; color: white; cursor: pointer; }
        .key:active { background: #00adb5; color: #121214; }
        .display-area { background: #121214; padding: 15px; text-align: center; font-size: 28px; font-weight: bold; border-radius: 8px; margin-bottom: 15px; color: #ff5722; border: 1px solid #2d2d35; min-height: 65px; }
        
        /* Quick Buttons */
        .quick-scores { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 15px; }
        .btn-quick { padding: 8px; font-size: 14px; background: #1a1a1f; border: 1px solid #2d2d35; color: #a0aec0; border-radius: 6px; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div id="setup-screen" class="card">
        <h1>Darts Counter</h1>
        
        <h3>1. Mode de Jeu</h3>
        <div class="mode-selector">
            <button class="btn btn-active" onclick="setMode(301)">301</button>
            <button class="btn" onclick="setMode(501)">501</button>
        </div>

        <h3>2. Joueurs / Équipes</h3>
        <div class="input-group">
            <input type="text" id="player-input" placeholder="Nom du joueur ou de l'équipe">
            <button class="btn btn-active" onclick="addPlayer()" style="flex: 0 0 60px;">+</button>
        </div>
        
        <div class="setup-buttons">
            <button class="btn-quick" onclick="loadDefaultTeam('TEAM CANON')">⚡ TEAM CANON</button>
            <button class="btn-quick" onclick="loadDuo('Luca', 'Loick')">👥 Luca vs Loick</button>
        </div>

        <div id="players-list" style="margin: 15px 0;"></div>

        <button class="btn btn-primary" onclick="startGame()">Lancer la partie 🎯</button>
    </div>

    <div id="game-screen" class="card hidden">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h2 id="game-title" style="margin: 0;">501</h2>
            <button class="btn-quick" onclick="resetGame()" style="padding: 5px 10px;">Quitter</button>
        </div>

        <div id="scoreboard" class="scoreboard"></div>

        <div class="display-area" id="score-display">0</div>

        <div class="quick-scores">
            <button class="btn-quick" onclick="quickInput(0)">D0 (Miss)</button>
            <button class="btn-quick" onclick="quickInput(26)">26</button>
            <button class="btn-quick" onclick="quickInput(41)">41</button>
            <button class="btn-quick" onclick="quickInput(60)">60</button>
            <button class="btn-quick" onclick="quickInput(85)">85</button>
            <button class="btn-quick" onclick="quickInput(100)">100</button>
            <button class="btn-quick" onclick="quickInput(140)">140</button>
            <button class="btn-quick" onclick="quickInput(180)">180</button>
        </div>

        <div class="keypad-grid">
            <button class="key" onclick="pressKey('1')">1</button>
            <button class="key" onclick="pressKey('2')">2</button>
            <button class="key" onclick="pressKey('3')">3</button>
            <button class="key" onclick="pressKey('4')">4</button>
            <button class="key" onclick="pressKey('5')">5</button>
            <button class="key" onclick="pressKey('6')">6</button>
            <button class="key" onclick="pressKey('7')">7</button>
            <button class="key" onclick="pressKey('8')">8</button>
            <button class="key" onclick="pressKey('9')">9</button>
            <button class="key" style="color: #ff5722;" onclick="pressKey('CLR')">⌫</button>
            <button class="key" onclick="pressKey('0')">0</button>
            <button class="key" style="background: #00adb5; color: #121214;" onclick="pressKey('ENT')">OK</button>
        </div>
    </div>
</div>

<script>
    let currentMode = 301;
    let players = [];
    let activePlayerIndex = 0;
    let currentInput = "";

    // Enregistre automatiquement l'application pour le mode hors connexion
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('sw.js').catch(err => console.log(err));
    }

    function setMode(mode) {
        currentMode = mode;
        document.querySelectorAll('.mode-selector .btn').forEach(btn => {
            btn.classList.toggle('btn-active', parseInt(btn.innerText) === mode);
        });
    }

    function renderSetupPlayers() {
        const container = document.getElementById('players-list');
        container.innerHTML = "";
        players.forEach((p, index) => {
            container.innerHTML += `
                <div class="player-badge">
                    <span>${p.name}</span>
                    <button class="remove-btn" onclick="removePlayer(${index})">✕</button>
                </div>
            `;
        });
    }

    function addPlayer() {
        const input = document.getElementById('player-input');
        const name = input.value.trim();
        if (name) {
            players.push({ name: name, score: currentMode, lastTurn: "-" });
            input.value = "";
            renderSetupPlayers();
        }
    }

    function removePlayer(index) {
        players.splice(index, 1);
        renderSetupPlayers();
    }

    function loadDefaultTeam(teamName) {
        players = [{ name: teamName, score: currentMode, lastTurn: "-" }, { name: "Adversaires", score: currentMode, lastTurn: "-" }];
        renderSetupPlayers();
    }

    function loadDuo(p1, p2) {
        players = [
            { name: p1, score: currentMode, lastTurn: "-" },
            { name: p2, score: currentMode, lastTurn: "-" }
        ];
        renderSetupPlayers();
    }

    function startGame() {
        if (players.length < 1) {
            alert("Ajoute au moins un joueur ou une équipe !");
            return;
        }
        players.forEach(p => p.score = currentMode);
        activePlayerIndex = 0;
        document.getElementById('game-title').innerText = currentMode;
        document.getElementById('setup-screen').classList.add('hidden');
        document.getElementById('game-screen').classList.remove('hidden');
        updateScoreboard();
    }

    function updateScoreboard() {
        const container = document.getElementById('scoreboard');
        container.innerHTML = "";
        players.forEach((p, index) => {
            const isActive = index === activePlayerIndex ? 'active' : '';
            container.innerHTML += `
                <div class="player-row ${isActive}">
                    <div class="player-info">
                        <span class="player-name">${p.name}</span>
                        <span class="player-last-turn">Volée précédente : ${p.lastTurn}</span>
                    </div>
                    <div class="player-score">${p.score}</div>
                </div>
            `;
        });
    }

    function pressKey(key) {
        const display = document.getElementById('score-display');
        if (key === 'CLR') {
            currentInput = currentInput.slice(0, -1);
        } else if (key === 'ENT') {
            submitScore(parseInt(currentInput) || 0);
            currentInput = "";
        } else {
            if (currentInput.length < 3) currentInput += key;
        }
        display.innerText = currentInput || "0";
    }

    function quickInput(val) {
        submitScore(val);
        currentInput = "";
        document.getElementById('score-display').innerText = "0";
    }

    function submitScore(points) {
        if (points > 180) {
            alert("Impossible de marquer plus de 180 points en une volée !");
            return;
        }

        let player = players[activePlayerIndex];
        
        if (player.score - points === 0) {
            player.score = 0;
            player.lastTurn = points;
            updateScoreboard();
            alert(`🎉 Victoire de ${player.name} !`);
            resetGame();
            return;
        } else if (player.score - points < 0) {
            // Règle du "Bust" (on dépasse, le score ne bouge pas)
            player.lastTurn = "Bust (0)";
        } else {
            player.score -= points;
            player.lastTurn = points;
        }

        activePlayerIndex = (activePlayerIndex + 1) % players.length;
        updateScoreboard();
    }

    function resetGame() {
        document.getElementById('setup-screen').classList.remove('hidden');
        document.getElementById('game-screen').classList.add('hidden');
    }
</script>
</body>
</html>
